{
  "name": "@sanity-labs/lint-core",
  "version": "0.2.0",
  "description": "Shared types and utilities for Sanity Lint",
  "author": "Sanity.io <hello@sanity.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-labs/sanity-lint.git",
    "directory": "packages/core"
  },
  "keywords": [
    "sanity",
    "lint",
    "eslint"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "groq-js": "catalog:"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.3.0"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
