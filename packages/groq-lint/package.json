{
  "name": "@sanity-labs/groq-lint",
  "version": "0.2.0",
  "description": "GROQ linting engine, rules, and CLI for Sanity Lint",
  "author": "Sanity.io <hello@sanity.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-labs/sanity-lint.git",
    "directory": "packages/groq-lint"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "groq-lint": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sanity/codegen": "^5.1.0",
    "@sanity-labs/groq-wasm": "workspace:*",
    "@sanity-labs/lint-core": "workspace:*",
    "groq-js": "catalog:"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.3.0"
  },
  "keywords": [
    "sanity",
    "groq",
    "lint",
    "linter"
  ],
  "publishConfig": {
    "access": "public"
  }
}
